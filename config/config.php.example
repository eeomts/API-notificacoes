<?php
/**
 * Configurações principais da aplicação
 * Copie este arquivo para config.php e preencha com seus valores:
 *   cp config/config.php.example config/config.php
 */

// Ambiente: 'development' ou 'production'
define('APP_ENV', 'development');
define('APP_VERSION', '1.0.0');

// -------------------------------------------------------
// Firebase / FCM V1
// -------------------------------------------------------
// ID do projeto Firebase (encontrado no console do Firebase)
define('FCM_PROJECT_ID', 'seu-projeto-id');

// Caminho para o arquivo JSON da service account do Google
// Gere em: Firebase Console > Configurações > Contas de Serviço > Gerar nova chave privada
define('FCM_SERVICE_ACCOUNT_PATH', __DIR__ . '/../storage/service-account.json');

// Endpoint FCM V1 (não alterar)
define('FCM_API_URL', 'https://fcm.googleapis.com/v1/projects/' . FCM_PROJECT_ID . '/messages:send');

// Endpoint para obter token OAuth2 do Google (não alterar)
define('GOOGLE_TOKEN_URL', 'https://oauth2.googleapis.com/token');

// Escopo necessário para FCM V1 (não alterar)
define('FCM_SCOPE', 'https://www.googleapis.com/auth/firebase.messaging');

// -------------------------------------------------------
// Autenticação da API
// -------------------------------------------------------
// Chave secreta Bearer para proteger os endpoints
// Gere uma chave forte: php -r "echo bin2hex(random_bytes(32));"
define('API_SECRET_KEY', 'troque-por-uma-chave-forte-aqui');

// -------------------------------------------------------
// Cache do token Google OAuth2
// -------------------------------------------------------
define('TOKEN_CACHE_FILE', __DIR__ . '/../storage/cache/google_token.json');

// -------------------------------------------------------
// Logging
// -------------------------------------------------------
define('LOG_FILE',  __DIR__ . '/../storage/logs/app.log');
define('LOG_LEVEL', APP_ENV === 'development' ? 'debug' : 'error');
